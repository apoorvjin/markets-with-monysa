---
import { storeLinks } from "../config/stores";

const platforms = [
  { key: "ios" as const, label: "App Store" },
  { key: "android" as const, label: "Google Play" },
];
---

<div class="cta-row">
  {
    platforms.map(({ key, label }) => {
      const link = storeLinks[key];
      return link.available ? (
        <a class="badge badge--live" href={link.url ?? "#"}>
          {label}
        </a>
      ) : (
        <span class="badge badge--soon" aria-disabled="true">
          {label} · Coming Soon
        </span>
      );
    })
  }
</div>

<style>
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border: 1px solid var(--border-strong);
  }

  .badge--soon {
    color: var(--text-secondary);
    background: var(--surface-card);
    cursor: default;
  }

  .badge--live {
    color: #000;
    background: var(--accent);
    border-color: var(--accent);
  }
</style>
