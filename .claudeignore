moby/ios/Podfile.lock
moby/macos/Podfile.lock
package-lock.json

# ── Node modules ──────────────────────────────────────────────────────────────
node_modules/

# ── Generated / compiled server output ────────────────────────────────────────
dist/

# ── Misc artefacts ─────────────────────────────────────────────────────────────
*.iml
moby/moby.iml
sector_lines.txt
architecture.html
