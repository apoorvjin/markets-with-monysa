moby/build/
moby/.dart_tool/
moby/linux/
moby/windows/
moby/web/

# ── iOS / macOS native ─────────────────────────────────────────────────────────
moby/ios/Pods/
moby/ios/.symlinks/
moby/ios/Flutter/flutter_export_environment.sh
moby/ios/Flutter/Generated.xcconfig
moby/macos/Pods/
