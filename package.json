{
  "name": "markets-api",
  "version": "1.0.0",
  "scripts": {
    "server:dev": "NODE_ENV=development tsx watch --env-file=.env server/index.ts",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=server_dist",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "web:build": "cd frontend && VITE_API_BASE_URL= pnpm --filter @monysa/web build",
    "share": "npm run web:build && echo '\\n✓ Frontend built. Run: ngrok http 5001\\n  Then open the ngrok URL — app + API on one tunnel.'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.97.0",
    "@upstash/redis": "^1.38.0",
    "express": "^5.0.1",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^13.10.0",
    "openai": "^6.32.0",
    "p-limit": "^7.3.0",
    "pdf-parse": "^2.4.5",
    "tsx": "^4.20.6",
    "ws": "^8.18.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.5.4"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "eslint": "^9.31.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
